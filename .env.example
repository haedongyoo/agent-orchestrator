# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/openclaw

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-64-char-hex-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Telegram ──────────────────────────────────────────────────────────────────
# Per-agent bot tokens are stored in DB (credentials_ref).
# This is the webhook base URL your Telegram bots will POST to.
TELEGRAM_WEBHOOK_BASE_URL=https://your-domain.com/api/connectors/telegram

# ── Email (IMAP/SMTP MVP) ──────────────────────────────────────────────────────
# Credentials stored via credentials_ref. These are defaults for local dev only.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
IMAP_HOST=imap.example.com
IMAP_PORT=993

# ── Security ──────────────────────────────────────────────────────────────────
# Vault / KMS reference prefix (credentials_ref values start with this)
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-only-token

# Fernet encryption key for API keys stored in the database.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# MUST be the same across all API and orchestrator instances.
ENCRYPTION_KEY=change-me-generate-a-real-fernet-key

# ── Agent Runtime / LiteLLM ───────────────────────────────────────────────────
# LiteLLM is provider-agnostic — switch providers by changing LLM_MODEL only.
#
# Examples:
#   Anthropic:  LLM_MODEL=anthropic/claude-opus-4-6   LLM_API_KEY=sk-ant-...
#   OpenAI:     LLM_MODEL=gpt-4o                       LLM_API_KEY=sk-...
#   Gemini:     LLM_MODEL=gemini/gemini-1.5-pro        LLM_API_KEY=AIza...
#   Groq:       LLM_MODEL=groq/llama-3.3-70b-versatile LLM_API_KEY=gsk_...
#   Ollama:     LLM_MODEL=ollama/llama3.3              LLM_API_BASE=http://ollama:11434
#               (no LLM_API_KEY needed for Ollama)
#   Bedrock:    LLM_MODEL=bedrock/anthropic.claude-3-5-sonnet-20241022-v2:0
#               AWS_ACCESS_KEY_ID=...  AWS_SECRET_ACCESS_KEY=...  AWS_REGION_NAME=us-east-1

LLM_MODEL=anthropic/claude-opus-4-6
LLM_API_KEY=sk-ant-...
LLM_API_BASE=                          # leave empty unless using Ollama / Azure custom endpoint
LLM_MAX_TOKENS=32768                   # claude-opus-4-6 supports up to 32K output tokens; lower for cost control

# The UUID of the agent this worker container serves (set per container instance)
AGENT_ID=

# ── Docker / Container Management ─────────────────────────────────────────────
# Docker network that agent containers are spawned onto (agent-net ONLY)
# Format: {compose_project_name}_{network_name}
DOCKER_AGENT_NETWORK=agent-orchestrator_agent-net
# Docker image used for all agent containers (built by: make build)
DOCKER_AGENT_IMAGE=openclaw/agent-runtime:latest
# Leave empty to use default Docker socket; set to tcp://... for remote daemon
DOCKER_HOST=

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=DEBUG
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
